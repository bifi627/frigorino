# Default: treat everything as text, normalize to LF in the repo.
# Windows checkouts still get CRLF in the working tree if core.autocrlf=true.
* text=auto eol=lf

# Windows-native scripts must keep CRLF on disk (Notepad / cmd hosts).
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.br binary
