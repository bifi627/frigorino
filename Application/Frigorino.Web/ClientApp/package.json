{
    "name": "frigorino.client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "start": "vite --host",
        "build": "tsc -b && vite build",
        "tsc": "tsc -b",
        "preview": "vite preview",
        "api:fetch": "dotnet build .. -c Debug",
        "api:gen": "openapi-ts -f openapi-ts.config.ts",
        "api": "npm run api:fetch && npm run api:gen",
