{
    "name": "frigorino.client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "start": "vite --host",
        "build": "tsc -b && vite build",
        "tsc": "tsc -b",
        "preview": "vite preview",
        "api:fetch": "dotnet build .. -c Debug",
        "api:gen": "openapi-ts -f openapi-ts.config.ts",
        "api": "npm run api:fetch && npm run api:gen",
        "lint": "eslint .",
        "prettier": "prettier --write .",
        "prettier:check": "prettier --check .",
        "fix": "eslint . --fix && prettier --write .",
        "routes:gen": "node generate-routes.mjs",
        "routes:check": "node generate-routes.mjs && git diff --exit-code src/routeTree.gen.ts"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.21",
        "@fullcalendar/react": "^6.1.20",
        "@grafana/faro-web-sdk": "^2.7.1",
        "@grafana/faro-web-tracing": "^2.8.0",
        "@hey-api/client-fetch": "^0.13.1",
        "@mui/icons-material": "^9.0.1",
        "@mui/material": "^9.0.1",
        "@mui/x-date-pickers": "^9.3.0",
        "@tanstack/react-query": "^5.101.0",
        "@tanstack/react-router": "^1.170.11",
        "@tanstack/react-router-devtools": "^1.167.0",
        "date-fns": "^4.4.0",
        "firebase": "^12.14.0",
        "i18next": "^26.3.0",
        "i18next-browser-languagedetector": "^8.2.0",
        "i18next-http-backend": "^4.0.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-i18next": "^17.0.8",
        "sonner": "^2.0.7",
        "zustand": "^5.0.6"
    },
    "overrides": {
        "@rollup/plugin-terser": "^1.0.0",
        "serialize-javascript": "^7.0.5"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@eslint/js": "^10.0.1",
        "@hey-api/openapi-ts": "^0.99.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tanstack/router-generator": "^1.167.13",
        "@tanstack/router-plugin": "^1.168.14",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "prettier": "^3.6.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14",
        "vite-plugin-compression2": "^2.5.3",
        "vite-plugin-pwa": "^1.3.0"
    }
}
