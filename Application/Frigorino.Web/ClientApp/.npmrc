# Supply-chain hardening for Frigorino npm installs.
# https://docs.npmjs.com/cli/v11/configuring-npm/npmrc

# Skip lifecycle scripts (preinstall / install / postinstall / prepare)
# during `npm install` — a common attack vector (event-stream, ua-parser-js,
# the 2024-09 chalk/debug poisoning). Our stack ships native binaries via
# optionalDependencies (esbuild / rolldown), not scripts, so this is safe.
# Does NOT affect `npm run <script>` invocations.
ignore-scripts=true

# Refuse package versions published less than N days ago. Most malicious
# releases get detected and yanked within 24-48h; 7d gives a quarantine
# buffer. Override per-command with `--min-release-age=0` if a real CVE
# patch needs to land fast. Requires npm 11+ (ships with Node 22+).
min-release-age=7
